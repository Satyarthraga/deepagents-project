# Copy to .env and fill in the keys you need

# Provider: kimi (default) | openai | google
DEEP_AGENT_PROVIDER=kimi

# --- Kimi K2.6 ---
MOONSHOT_API_KEY=         # https://platform.kimi.ai/console/api-keys

# --- OpenAI (optional) ---
# DEEP_AGENT_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# --- Google Gemini (optional) ---
# DEEP_AGENT_PROVIDER=google
# GOOGLE_API_KEY=
# GOOGLE_MODEL=gemini-2.0-flash

# No search API key needed — DuckDuckGo is free and keyless
